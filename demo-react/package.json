{
  "name": "fits-pyramid-demo-react",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "React harness that renders a FITS pyramid through the fits-pyramid/react <FitsViewer> component — visual verification of the M5 React delivery tier (decision D12).",
  "scripts": {
    "build-lib": "npm --prefix ../fits-pyramid run build",
    "predev": "npm run build-lib",
    "dev": "vite",
    "prebuild": "npm run build-lib",
    "build": "vite build",
    "preview": "vite preview",
    "pretypecheck": "npm run build-lib",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
